# -----------------------------------------------------------------------------
# RoboNeuron .gitignore
# Goal: keep source/configs/docs in Git, ignore local build/cache/runtime artifacts.
# -----------------------------------------------------------------------------

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class

# Build / packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/
wheels/

# Test / lint / type-check cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Virtual environments / local Python env
.venv/
.venvs/
venv/
env/
ENV/
__pypackages__/
.python-version

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Logs / runtime temp
*.log
logs/
tmp/
temp/

# ROS 2 generated artifacts
# Keep only ros/roboneuron_interfaces source files in Git.
# Users should rebuild ros/ locally with colcon on their own machines.
ros/build/
ros/install/
ros/log/
ros/**/build/
ros/**/install/
ros/**/log/

# ROS bag / database artifacts
*.bag
*.bag.active
*.db3

# Local model / checkpoint artifacts (avoid committing large binaries)
checkpoints/
weights/
models/
*.ckpt
*.pt
*.pth
*.safetensors
*.onnx
.cache/

# Local config / machine-specific files
.codex
.env
.env.*
!.env.example
nomcp-version

# Windows ADS filename artifacts occasionally introduced in repos
*:[Zz]one.Identifier*

# Local top-level reference trees are optional and should not be committed by default.
/references/
